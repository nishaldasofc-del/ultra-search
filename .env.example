# ── OpenRouter (LLM + Embeddings) ─────────────────────────────────────────────
# Sign up free at https://openrouter.ai
# Free tier: 200 LLM requests/day, embeddings appear to have no stated daily limit
OPENROUTER_API_KEY=your_openrouter_key_here

# ── Models (free tier — $0 cost) ─────────────────────────────────────────────
# These are the free models. Do NOT change unless you want to pay.
EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
FAST_MODEL=google/gemini-2.0-flash-exp:free
DEEP_MODEL=deepseek/deepseek-chat:free
EMBEDDING_DIM=1024

# ── Database ──────────────────────────────────────────────────────────────────
# Render internal URL (copy from Render dashboard after creating PostgreSQL)
POSTGRES_URL=postgresql://user:pass@hostname/dbname

# Render internal Redis URL
REDIS_URL=redis://red-xxxx.render.com:6379

# ── Vector DB (Qdrant) ────────────────────────────────────────────────────────
# Your Qdrant service hostname on Render (internal)
QDRANT_HOST=ultrasearch-qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=pages

# ── Crawler ───────────────────────────────────────────────────────────────────
CRAWLER_CONCURRENCY=8
CRAWLER_DELAY_MS=300
CRAWLER_MAX_DEPTH=4
CRAWLER_MAX_PAGES_PER_JOB=500

# ── No search API keys needed. Your crawler IS your search index. ─────────────
